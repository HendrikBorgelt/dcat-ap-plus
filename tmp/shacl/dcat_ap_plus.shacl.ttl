            sh:order 6 ;
            sh:path dcterms:hasPart ],
        [ sh:class dcatapplus:AgenticEntity ;
            sh:description "The slot to provide the AgenticEntity of which theAgenticEntity is a part." ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path dcterms:isPartOf ],
        [ sh:class dcatapplus:DefinedTerm ;
