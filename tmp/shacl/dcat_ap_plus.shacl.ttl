    rdfs:comment "See [DCAT-AP specs:TimeInstant](https://semiceu.github.io/DCAT-AP/releases/3.0.0/#TimeInstant)" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
