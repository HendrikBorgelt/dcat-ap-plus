dcatapplus:ProvenanceStatement a sh:NodeShape ;
    rdfs:comment "See [DCAT-AP specs:ProvenanceStatement](https://semiceu.github.io/DCAT-AP/releases/3.0.0/#ProvenanceStatement)" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
