dcatapplus:Catalogue a sh:NodeShape ;
    rdfs:comment "See [DCAT-AP specs:Catalogue](https://semiceu.github.io/DCAT-AP/releases/3.0.0/#Catalogue)" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A free-text account of the Catalogue." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcterms:description ],
        [ sh:class dcatapplus:Location ;
            sh:description "A geographical area covered by the Catalogue." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path dcterms:spatial ],
        [ sh:class dcatapplus:Document ;
            sh:description "A web page that acts as the main page for the Catalogue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path foaf:homepage ],
        [ sh:class dcatapplus:CatalogueRecord ;
            sh:description "A Catalogue Record that is part of the Catalogue." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path dcat:record ],
        [ sh:datatype xsd:date ;
            sh:description "The most recent date on which the Catalogue was modified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path dcterms:modified ],
        [ sh:class dcatapplus:Catalogue ;
            sh:description "A related Catalogue that is part of the described Catalogue." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path dcterms:hasPart ],
        [ sh:class dcatapplus:Dataset ;
            sh:description "A Dataset that is part of the Catalogue." ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path dcat:dataset ],
        [ sh:datatype xsd:string ;
            sh:description "A name given to the Catalogue." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path dcterms:title ],
        [ sh:class dcatapplus:LegalResource ;
            sh:description "The legislation that mandates the creation or management of the Catalog." ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path dcatap:applicableLegislation ],
        [ sh:class dcatapplus:ConceptScheme ;
            sh:description "A knowledge organization system used to classify the Resources that are in the Catalogue." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path dcat:themeTaxonomy ],
        [ sh:class dcatapplus:Agent ;
            sh:description "An entity responsible for the creation of the catalogue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path dcterms:creator ],
        [ sh:class dcatapplus:Catalogue ;
            sh:description "A catalogue whose contents are of interest in the context of this catalogue." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path dcat:catalog ],
        [ sh:class dcatapplus:RightsStatement ;
            sh:description "A statement that specifies rights associated with the Catalogue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path dcterms:rights ],
        [ sh:class dcatapplus:Agent ;
            sh:description "An entity (organisation) responsible for making the Catalogue available." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path dcterms:publisher ],
        [ sh:class dcatapplus:PeriodOfTime ;
            sh:description "A temporal period that the Catalogue covers." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path dcterms:temporal ],
        [ sh:class dcatapplus:LinguisticSystem ;
            sh:description "A language used in the textual metadata describing titles, descriptions, etc. of the Datasets in the Catalogue." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path dcterms:language ],
        [ sh:class dcatapplus:LicenseDocument ;
            sh:description "A licence under which the Catalogue can be used or reused." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path dcterms:license ],
        [ sh:datatype xsd:date ;
            sh:description "The date of formal issuance (e.g., publication) of the Catalogue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path dcterms:issued ],
        [ sh:class dcatapplus:DataService ;
            sh:description "A site or end-point (Data Service) that is listed in the Catalogue." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path dcat:service ] ;
    sh:targetClass dcat:Catalog .

dcatapplus:DataService a sh:NodeShape ;
    rdfs:comment "See [DCAT-AP specs:DataService](https://semiceu.github.io/DCAT-AP/releases/3.0.0/#DataService)" ;
    sh:closed true ;
